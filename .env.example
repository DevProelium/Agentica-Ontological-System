# Bridge Local – Agentica Ontological System
# Copia este archivo como .env y configura tus valores locales.
# NUNCA subas el archivo .env al repositorio.

# Neo4j (base de datos de grafos)
# El sistema funciona sin Neo4j en modo memoria
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu-contraseña-local

# Puerto del Bridge WebSocket
PORT=3001
